            "NEW_ACHIEVEMENT_1808_21_NAME"          "Le colonel"
            "NEW_ACHIEVEMENT_1808_21_DESC"          "Tuez 1 000 poulets."
            "NEW_ACHIEVEMENT_1808_22_NAME"          "Mon bon ami Charles"
            "NEW_ACHIEVEMENT_1808_22_DESC"          "Utilisez la fonction de ping en jeu 1 000 fois au total."
            "NEW_ACHIEVEMENT_1808_23_NAME"          "(Grognement agacé)"
            "NEW_ACHIEVEMENT_1808_23_DESC"          "Devenez un Papa en colère."
            "NEW_ACHIEVEMENT_1808_24_NAME"          "Ragequit"
