            "NEW_ACHIEVEMENT_1842_13_DESC"          "Uccidi un nemico a lungo raggio con un fucile usando il mirino laser."
            "NEW_ACHIEVEMENT_1842_14_NAME"          "Viaggiatore del mondo"
            "NEW_ACHIEVEMENT_1842_14_DESC"          "Completa un round su una mappa creata dalla community."
            "NEW_ACHIEVEMENT_1842_15_NAME"          "È UNA TRAPPOLA"
            "NEW_ACHIEVEMENT_1842_15_DESC"          "Come Traditore, usa una trappola per uccidere un giocatore."
            "NEW_ACHIEVEMENT_1842_16_NAME"          "Cane Pazzo"
            "NEW_ACHIEVEMENT_1842_16_DESC"          "Usa il cane esplosivo per uccidere un giocatore sulla mappa 747."
            "NEW_ACHIEVEMENT_1842_17_NAME"          "Non guardare in basso"
            "NEW_ACHIEVEMENT_1842_17_DESC"          "Gioca cinque round su Junkbaby senza subire 25 o più danni da caduta."
            "NEW_ACHIEVEMENT_1842_18_NAME"          "Pozzetto protetto"
            "NEW_ACHIEVEMENT_1842_18_DESC"          "Ottieni la vittoria come Traditore o Detective sulla mappa 747."
            "NEW_ACHIEVEMENT_1842_19_NAME"          "Caduta libera"
            "NEW_ACHIEVEMENT_1842_19_DESC"          "Caduta dall'aereo sul 747."
            "NEW_ACHIEVEMENT_1842_20_NAME"          "Strapazzato"
            "NEW_ACHIEVEMENT_1842_20_DESC"          "Come pollo, fatti uccidere dal mondo."
            "NEW_ACHIEVEMENT_1842_22_NAME"          "Tagger"
            "NEW_ACHIEVEMENT_1842_22_DESC"          "Spruzza 100 volte."
            "NEW_ACHIEVEMENT_1842_24_NAME"          "Il sussurratore di idioti"
            "NEW_ACHIEVEMENT_1842_24_DESC"          "Come Traditore, convinci qualcuno a uccidere 2 compagni di squadra al tuo comando."
            "NEW_ACHIEVEMENT_1842_25_NAME"          "È la spia rossa"
            "NEW_ACHIEVEMENT_1842_25_DESC"          "Usa la Chat rapida per dire che un corpo è un Traditore."
            "NEW_ACHIEVEMENT_1842_26_NAME"          "Ultimo soccorritore"
            "NEW_ACHIEVEMENT_1842_26_DESC"          "Come detective, rimani in vita quando tutti gli innocenti sono morti."
            "NEW_ACHIEVEMENT_1842_27_NAME"          "Furtivo"
            "NEW_ACHIEVEMENT_1842_27_DESC"          "Come Traditore, vinci un round con almeno 10 persone senza essere attaccato da un altro giocatore."
            "NEW_ACHIEVEMENT_1842_28_NAME"          "Co-op"
            "NEW_ACHIEVEMENT_1842_28_DESC"          "Come Detective, cura un collega Detective con la tua stazione medica."
            "NEW_ACHIEVEMENT_1842_29_NAME"          "Replay istantaneo"
            "NEW_ACHIEVEMENT_1842_29_DESC"          "Fatti visualizzare entro 10 secondi dall'aver ottenuto un'uccisione."
            "NEW_ACHIEVEMENT_1842_30_NAME"          "Decapitazione"
            "NEW_ACHIEVEMENT_1842_30_DESC"          "Decapita un nemico con un disco da rimbalzo."
            "NEW_ACHIEVEMENT_1842_31_NAME"          "Conseguenze previste"
            "NEW_ACHIEVEMENT_1842_31_DESC"          "Spingi qualcuno a morire con il piede di porco."
            "NEW_ACHIEVEMENT_1849_0_NAME"           "Sei Edgar Ross?"
            "NEW_ACHIEVEMENT_1849_0_DESC"           "Uccidi un traditore nemico con la S&W."
            "NEW_ACHIEVEMENT_1849_1_NAME"           "Cerca di ricordare le basi del CQC"
            "NEW_ACHIEVEMENT_1849_1_DESC"           "Uccidi 3 traditori nemici con il piede di porco."
            "NEW_ACHIEVEMENT_1849_2_NAME"           "Pesce in un barile"
            "NEW_ACHIEVEMENT_1849_2_DESC"           "Uccidi 5 nemici accecati."
            "NEW_ACHIEVEMENT_1849_3_NAME"           "Il Signore"
            "NEW_ACHIEVEMENT_1849_3_DESC"           "Come Traditore, uccidi 3 nemici nello stesso round con la LMG in Clubhouse."
            "NEW_ACHIEVEMENT_1849_4_NAME"           "Fuze l'Ostaggio"
            "NEW_ACHIEVEMENT_1849_4_DESC"           "Ottieni 10 uccisioni con la trappola del disco da hockey in Clubhouse."
            "NEW_ACHIEVEMENT_1849_5_NAME"           "Il regalo perfetto"
            "NEW_ACHIEVEMENT_1849_5_DESC"           "Ottieni l'RPG su Cliff."
            "NEW_ACHIEVEMENT_1849_6_NAME"           "Sì, sono una nuova classe"
            "NEW_ACHIEVEMENT_1849_6_DESC"           "Nasci come pollo con l'elemento estetico Tycho equipaggiato."
        }
    }
