            "NEW_ACHIEVEMENT_1842_15_DESC"          "Come Traditore, usa una trappola per uccidere un giocatore."
            "NEW_ACHIEVEMENT_1842_16_NAME"          "Cane Pazzo"
            "NEW_ACHIEVEMENT_1842_16_DESC"          "Usa il cane esplosivo per uccidere un giocatore sulla mappa 747."
            "NEW_ACHIEVEMENT_1842_17_NAME"          "Non guardare in basso"
            "NEW_ACHIEVEMENT_1842_17_DESC"          "Gioca cinque round su Junkbaby senza subire 25 o più danni da caduta in una volta sola."
            "NEW_ACHIEVEMENT_1842_18_NAME"          "Cabina di pilotaggio sicura"
            "NEW_ACHIEVEMENT_1842_18_DESC"          "Ottieni la vittoria come Traditore o Detective sulla mappa 747."
            "NEW_ACHIEVEMENT_1842_19_NAME"          "Caduta libera"
            "NEW_ACHIEVEMENT_1842_19_DESC"          "Cadi fuori dall'aereo su 747."
            "NEW_ACHIEVEMENT_1842_20_NAME"          "Uova strapazzate"
            "NEW_ACHIEVEMENT_1842_20_DESC"          "Come pollo, muori a causa dell'ambiente di gioco."
            "NEW_ACHIEVEMENT_1842_22_NAME"          "Graffitaro"
            "NEW_ACHIEVEMENT_1842_22_DESC"          "Usa uno spray 100 volte."
            "NEW_ACHIEVEMENT_1842_24_NAME"          "L'uomo che sussurrava agli idioti"
            "NEW_ACHIEVEMENT_1842_24_DESC"          "Come Traditore, fai in modo che qualcuno uccida 2 compagni di squadra al tuo comando."
            "NEW_ACHIEVEMENT_1842_25_NAME"          "È lui la Spia Rossa"
            "NEW_ACHIEVEMENT_1842_25_DESC"          "Usa la Chat Rapida per segnalare che un corpo è un Traditore."
            "NEW_ACHIEVEMENT_1842_26_NAME"          "Ultimo baluardo"
            "NEW_ACHIEVEMENT_1842_26_DESC"          "Come Detective, resta in vita quando tutti gli innocenti sono morti."
            "NEW_ACHIEVEMENT_1842_27_NAME"          "Furtivo"
            "NEW_ACHIEVEMENT_1842_27_DESC"          "Come Traditore, vinci un round con almeno 10 giocatori senza mai farti attaccare da nessuno."
            "NEW_ACHIEVEMENT_1842_28_NAME"          "Cooperazione"
            "NEW_ACHIEVEMENT_1842_28_DESC"          "Come Detective, cura un collega Detective con la tua stazione medica."
            "NEW_ACHIEVEMENT_1842_29_NAME"          "Replay istantaneo"
            "NEW_ACHIEVEMENT_1842_29_DESC"          "Fatti visualizzare entro 10 secondi dall'aver ottenuto un'uccisione."
            "NEW_ACHIEVEMENT_1842_30_NAME"          "Decapitazione"
            "NEW_ACHIEVEMENT_1842_30_DESC"          "Decapita un nemico con un disco rimbalzante."
            "NEW_ACHIEVEMENT_1842_31_NAME"          "Conseguenze impreviste"
            "NEW_ACHIEVEMENT_1842_31_DESC"          "Spingi qualcuno nel vuoto con il piede di porco."
            "NEW_ACHIEVEMENT_1849_0_NAME"           "Sei Edgar Ross?"
            "NEW_ACHIEVEMENT_1849_0_DESC"           "Uccidi un Traditore nemico con la S&W."
            "NEW_ACHIEVEMENT_1849_1_NAME"           "Ricorda le basi del CQC"
            "NEW_ACHIEVEMENT_1849_1_DESC"           "Uccidi 3 Traditori nemici con il piede di porco."
            "NEW_ACHIEVEMENT_1849_2_NAME"           "Come pesci in un barile"
            "NEW_ACHIEVEMENT_1849_2_DESC"           "Uccidi 5 nemici che sono stati accecati."
            "NEW_ACHIEVEMENT_1849_3_NAME"           "Il Padrone"
            "NEW_ACHIEVEMENT_1849_3_DESC"           "Come Traditore, uccidi 3 nemici nello stesso round con la LMG su Clubhouse."
            "NEW_ACHIEVEMENT_1849_4_NAME"           "Fuza l'ostaggio"
            "NEW_ACHIEVEMENT_1849_4_DESC"           "Ottieni 10 uccisioni con la trappola del disco da hockey su Clubhouse."
            "NEW_ACHIEVEMENT_1849_5_NAME"           "Il regalo perfetto"
            "NEW_ACHIEVEMENT_1849_5_DESC"           "Ottieni l'RPG su Cliff."
            "NEW_ACHIEVEMENT_1849_6_NAME"           "Sì, sono una nuova classe"
            "NEW_ACHIEVEMENT_1849_6_DESC"           "Nasci come pollo con l'oggetto estetico Tycho equipaggiato."
        }
    }
