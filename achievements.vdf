    "spanish"
    {
        "Tokens"
        {
            "NEW_ACHIEVEMENT_1808_1_NAME"           "Imparable"
            "NEW_ACHIEVEMENT_1808_1_DESC"           "Sobrevive a tres rondas consecutivas sin morir. (Mín. 6 jugadores)"
            "NEW_ACHIEVEMENT_1808_2_NAME"           "¡Véngame!"
            "NEW_ACHIEVEMENT_1808_2_DESC"           "Mata a un enemigo que haya matado recientemente a un amigo."
            "NEW_ACHIEVEMENT_1808_3_NAME"           "Trilogía del trauma"
            "NEW_ACHIEVEMENT_1808_3_DESC"           "Descubre tres cuerpos consecutivos que no hayas matado tú."
            "NEW_ACHIEVEMENT_1808_4_NAME"           "Lazo del destino"
            "NEW_ACHIEVEMENT_1808_4_DESC"           "Mata a tu asesino con tu último disparo antes de morir."
            "NEW_ACHIEVEMENT_1808_5_NAME"           "Boy Scout"
            "NEW_ACHIEVEMENT_1808_5_DESC"           "Comienza y termina un mapa con tu karma NUNCA cayendo por debajo del 96% del máximo, incluso a mitad de ronda."
            "NEW_ACHIEVEMENT_1808_6_NAME"           "Mort"
            "NEW_ACHIEVEMENT_1808_6_DESC"           "Conviértete en gallina."
            "NEW_ACHIEVEMENT_1808_7_NAME"           "Amigo"
            "NEW_ACHIEVEMENT_1808_7_DESC"           "Marca a un amigo como AMIGO usando la interfaz del juego. ¡Sí!"
            "NEW_ACHIEVEMENT_1808_8_NAME"           "Vandalismo"
            "NEW_ACHIEVEMENT_1808_8_DESC"           "Pinta un grafiti junto a un cadáver."
            "NEW_ACHIEVEMENT_1808_9_NAME"           "Vuelta al mundo"
            "NEW_ACHIEVEMENT_1808_9_DESC"           "Completa una ronda en todos los mapas oficiales y en al menos un mapa no oficial."
            "NEW_ACHIEVEMENT_1808_10_NAME"          "¡Lo lograste!"
            "NEW_ACHIEVEMENT_1808_10_DESC"          "Juega a TTT Classic por primera vez."
            "NEW_ACHIEVEMENT_1808_11_NAME"          "Gallina Miku"
            "NEW_ACHIEVEMENT_1808_11_DESC"          "Aparece como gallina con el cosmético de Hatsune Miku equipado."
            "NEW_ACHIEVEMENT_1808_12_NAME"          "Uno de los nuestros"
            "NEW_ACHIEVEMENT_1808_12_DESC"          "Visita el Discord de TTTC."
            "NEW_ACHIEVEMENT_1808_13_NAME"          "Hola Crazydog"
            "NEW_ACHIEVEMENT_1808_13_DESC"          "Juega a TTT con Crazydog."
            "NEW_ACHIEVEMENT_1808_14_NAME"          "Crítico severo"
            "NEW_ACHIEVEMENT_1808_14_DESC"          "Mata al creador del mapa actual (debe ser un enemigo)."
            "NEW_ACHIEVEMENT_1808_16_NAME"          "Diezmando a la manada"
            "NEW_ACHIEVEMENT_1808_16_DESC"          "Acumula 10 000 muertes en total de cada rol: Traidor, Inocente y Detective."
            "NEW_ACHIEVEMENT_1808_17_NAME"          "Modelo a seguir"
            "NEW_ACHIEVEMENT_1808_17_DESC"          "Termina diez rondas consecutivas con karma perfecto."
            "NEW_ACHIEVEMENT_1808_18_NAME"          "Gran ganador"
            "NEW_ACHIEVEMENT_1808_18_DESC"          "Gana 100 rondas."
            "NEW_ACHIEVEMENT_1808_19_NAME"          "Gran perdedor"
            "NEW_ACHIEVEMENT_1808_19_DESC"          "Pierde 100 rondas."
            "NEW_ACHIEVEMENT_1808_21_NAME"          "El Coronel"
            "NEW_ACHIEVEMENT_1808_21_DESC"          "Mata a 1000 pollos."
            "NEW_ACHIEVEMENT_1808_22_NAME"          "Mi buen amigo Charles"
            "NEW_ACHIEVEMENT_1808_22_DESC"          "Usa la función de ping del juego 1000 veces en total."
            "NEW_ACHIEVEMENT_1808_23_NAME"          "(Gruñido molesto)"
            "NEW_ACHIEVEMENT_1808_23_DESC"          "Conviértete en un Padre enfadado."
            "NEW_ACHIEVEMENT_1808_24_NAME"          "Ragequit"
            "NEW_ACHIEVEMENT_1808_24_DESC"          "Desconéctate del servidor inmediatamente después de ser asesinado."
            "NEW_ACHIEVEMENT_1808_25_NAME"          "Pollo Loco"
            "NEW_ACHIEVEMENT_1808_25_DESC"          "Mata a un jugador mientras juegas como gallina."
            "NEW_ACHIEVEMENT_1808_26_NAME"          "¡Cacarea esto!"
            "NEW_ACHIEVEMENT_1808_26_DESC"          "Como gallina, mata a diez jugadores."
            "NEW_ACHIEVEMENT_1808_27_NAME"          "Por los pelos"
            "NEW_ACHIEVEMENT_1808_27_DESC"          "Desactiva con éxito un C4 plantado."
            "NEW_ACHIEVEMENT_1808_28_NAME"          "¡Yoink!"
            "NEW_ACHIEVEMENT_1808_28_DESC"          "Consigue la última muerte de un Traidor usando un arma específica de Traidor."
            "NEW_ACHIEVEMENT_1808_29_NAME"          "Más allá del deber"
            "NEW_ACHIEVEMENT_1808_29_DESC"          "Como Inocente, elimina a tres o más Traidores por ti mismo en una sola ronda."
            "NEW_ACHIEVEMENT_1808_30_NAME"          "Espío con mi ojito"
            "NEW_ACHIEVEMENT_1808_30_DESC"          "Localiza y elimina a un traidor basándose en un ping de ADN."
            "NEW_ACHIEVEMENT_1808_31_NAME"          "Seguro que conseguirás la silla"
            "NEW_ACHIEVEMENT_1808_31_DESC"          "Como detective, derrota al último traidor en una confrontación 1 contra 1 usando el prototipo UMP."
            "NEW_ACHIEVEMENT_1837_0_NAME"           "Jugador de equipo"
            "NEW_ACHIEVEMENT_1837_0_DESC"           "Como detective, haz que tus aliados recuperen al menos 75 de salud total de tu estación de salud colocada."
            "NEW_ACHIEVEMENT_1837_1_NAME"           "Prevención del suicidio"
            "NEW_ACHIEVEMENT_1837_1_DESC"           "Como detective, mata a un traidor suicida con un disparo en la cabeza o con un disparo S&W antes de que detone."
            "NEW_ACHIEVEMENT_1837_2_NAME"           "Deberías meterte en política"
            "NEW_ACHIEVEMENT_1837_2_DESC"           "Como inocente, utiliza un cuchillo para apuñalar por la espalda a un traidor."
            "NEW_ACHIEVEMENT_1837_3_NAME"           "Le dispararon al sheriff"
            "NEW_ACHIEVEMENT_1837_3_DESC"           "Venga al detective matando al traidor que los derribó."
            "NEW_ACHIEVEMENT_1837_4_NAME"           "carlos"
            "NEW_ACHIEVEMENT_1837_4_DESC"           "Como detective, sobrevive a una ronda sin escanear ningún cuerpo y sin matar."
            "NEW_ACHIEVEMENT_1837_5_NAME"           "Esto es mío ahora"
            "NEW_ACHIEVEMENT_1837_5_DESC"           "Como inocente, saquea y equipa un objeto específico de Traidor."
            "NEW_ACHIEVEMENT_1837_6_NAME"           "Perfección"
            "NEW_ACHIEVEMENT_1837_6_DESC"           "Elimina a todos los traidores sin bajas inocentes. (Mín. 10 jugadores)"
            "NEW_ACHIEVEMENT_1837_7_NAME"           "Planificador maestro"
            "NEW_ACHIEVEMENT_1837_7_DESC"           "Habla durante al menos un minuto usando el chat de voz del traidor."
            "NEW_ACHIEVEMENT_1837_8_NAME"           "Equipo de limpieza"
            "NEW_ACHIEVEMENT_1837_8_DESC"           "Como traidor, gana sin que los inocentes encuentren cadáveres de las muertes realizadas por los traidores durante la ronda. (Mín. 8 jugadores)"
            "NEW_ACHIEVEMENT_1837_10_NAME"          "Las leyes de la traición de Newton"
            "NEW_ACHIEVEMENT_1837_10_DESC"          "Como traidor, utiliza el lanzador Newton para empujar a tres inocentes o detectives a la muerte."
            "NEW_ACHIEVEMENT_1837_11_NAME"          "Mala Medicina"
            "NEW_ACHIEVEMENT_1837_11_DESC"          "Como traidor, usa un botiquín cuando tengas 45 HP o menos."
            "NEW_ACHIEVEMENT_1837_13_NAME"          "Realmente nunca estuve de tu lado."
            "NEW_ACHIEVEMENT_1837_13_DESC"          "Como traidor, mata a un inocente que acaba de matar en equipo a otro inocente."
            "NEW_ACHIEVEMENT_1837_14_NAME"          "Haciendo tocino"
